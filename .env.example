# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_admin_telegram_id

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Admin Panel
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_secure_password
FLASK_SECRET_KEY=your_random_secret_key

# Deployment (optional)
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_PATH=/webhook

# Логирование: по умолчанию в проде остаются только ошибки (ERROR).
# Поднимите до INFO/DEBUG для локальной отладки.
LOG_LEVEL=ERROR

# Кэш (cache.py) и общий backend для лимитов CRM (Flask-Limiter).
# Если не задан — используется in-memory кэш/лимиты (только в рамках
# ОДНОГО процесса).
#
# ВАЖНО: CRM (app.py) и бот (bot.py) сбрасывают кэш списка игр через один
# и тот же модуль cache.py при создании/редактировании игры или смене
# статуса заявки. Если CRM и бот — РАЗНЫЕ процессы/контейнеры (типичный
# прод-деплой, когда бот не запущен как фоновый поток внутри CRM через
# RUN_BOT_IN_BACKGROUND=1), то без REDIS_URL это будет два независимых
# in-memory кэша, и сброс из CRM не будет виден боту — новые игры появятся
# у пользователей только через GAMES_CACHE_TTL секунд (см. cache.py) или
# после перезапуска бота. Задайте REDIS_URL, чтобы кэш был общим и
# инвалидация срабатывала мгновенно в обоих процессах.
REDIS_URL=

# Rate limiting
BOT_RATE_LIMIT_PER_SECOND=10
CRM_RATE_LIMIT_PER_SECOND=10
LOGIN_RATE_LIMIT=5 per minute

# CRM: размер страницы в таблицах (пагинация)
CRM_PAGE_SIZE=20

# Cache-Control для статики Flask (секунды)
STATIC_CACHE_SECONDS=86400

# Включите в production за HTTPS (иначе cookie сессии не будет ставиться
# по обычному HTTP — удобно для локальной разработки оставить 0)
SESSION_COOKIE_SECURE=0

# Запускать ли Telegram-бота в фоновом потоке внутри процесса CRM
# (только для запуска "python app.py" в режиме __main__; под gunicorn
# бот нужно запускать отдельным процессом/сервисом)
RUN_BOT_IN_BACKGROUND=0

# Оплата картой через бота (Telegram Payments).
# Если не задан — кнопка «Оплатить картой» показывает демо-заглушку
# (интерфейс работает, но подтверждает оплату администратор в CRM).
# Чтобы включить настоящую оплату: @BotFather -> /mybots -> ваш бот ->
# Payments -> подключить провайдера (можно тестовый, без реальных денег) и
# вставить сюда выданный provider_token.
PAYMENT_PROVIDER_TOKEN=
