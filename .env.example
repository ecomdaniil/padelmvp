# Telegram Bot
BOT_TOKEN=your_bot_token_here
# Личный Telegram ID админа (число). Можно несколько через запятую.
# Альтернатива — поле в CRM «О клубе» или /bindadmin <ADMIN_BIND_TOKEN>.
ADMIN_CHAT_ID=your_admin_telegram_id
# Опционально: секрет для команды /bindadmin в боте
ADMIN_BIND_TOKEN=

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Admin Panel
ADMIN_LOGIN=admin
# Предпочтительно хеш (не храните пароль открытым текстом в проде):
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your_secure_password', method='pbkdf2:sha256'))"
ADMIN_PASSWORD_HASH=
# Только для локальной разработки (если хеш не задан):
# ADMIN_PASSWORD=your_secure_password
FLASK_SECRET_KEY=your_random_secret_key

# Deployment (optional)
# Полный публичный HTTPS origin без пути, например https://your-app.onrender.com
# На Render, если пусто — подставится RENDER_EXTERNAL_URL автоматически.
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
# Секрет для X-Telegram-Bot-Api-Secret-Token (если пусто — дериват от FLASK_SECRET_KEY)
WEBHOOK_SECRET_TOKEN=
# 1 = требовать X-Telegram-Bot-Api-Secret-Token (строже).
# 0 = принимать webhook без secret (надёжнее на Render, путь /webhook всё равно не публичный).
WEBHOOK_ENFORCE_SECRET=0
WEBHOOK_RATE_LIMIT=30 per second

# Логирование: по умолчанию в проде остаются только ошибки (ERROR).
# Поднимите до INFO/DEBUG для локальной отладки.
LOG_LEVEL=ERROR
# Никогда не включайте FLASK_DEBUG=1 в production
FLASK_DEBUG=0

# Кэш (cache.py) и общий backend для лимитов CRM (Flask-Limiter).
# Если не задан — используется in-memory кэш/лимиты (только в рамках
# ОДНОГО процесса).
#
# ВАЖНО: CRM (app.py) и бот (bot.py) сбрасывают кэш списка игр через один
# и тот же модуль cache.py при создании/редактировании игры или заявки.
# Если CRM и бот — РАЗНЫЕ процессы без REDIS_URL, инвалидация не шарится.
REDIS_URL=

# Rate limiting
BOT_RATE_LIMIT_PER_SECOND=10
CRM_RATE_LIMIT_PER_SECOND=10
LOGIN_RATE_LIMIT=5 per minute

# CRM: размер страницы в таблицах (пагинация)
CRM_PAGE_SIZE=20

# Cache-Control для статики Flask (секунды)
STATIC_CACHE_SECONDS=86400

# Включите в production за HTTPS (иначе cookie сессии не будет ставиться
# по обычному HTTP — удобно для локальной разработки оставить 0)
SESSION_COOKIE_SECURE=0
# Срок жизни сессии CRM (часы)
SESSION_LIFETIME_HOURS=12

# Запускать ли Telegram-бота в фоновом потоке внутри процесса CRM.
# На Render по умолчанию включается автоматически (не держите bot.py на Mac —
# при закрытии крышки polling останавливается).
RUN_BOT_IN_BACKGROUND=0

# Локальный bind для `python app.py` (на PaaS обычно HOST=0.0.0.0)
HOST=127.0.0.1

# Клуб работает по московскому времени (Europe/Moscow зашито в коде).
APP_TIMEZONE=Europe/Moscow

# Сколько дней хранить старые данные перед автоочисткой (ежедневно в 03:00
# по Москве)
DATA_RETENTION_DAYS=60

# Оплата картой через бота (Telegram Payments).
PAYMENT_PROVIDER_TOKEN=
